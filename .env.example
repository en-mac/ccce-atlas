# ============================================================================
# ccce-atlas Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=True

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL + PostGIS)
# ----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ccce_atlas
POSTGRES_USER=ccce_atlas
POSTGRES_PASSWORD=ccce_atlas_dev

# PostgreSQL performance tuning (local development)
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=16MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_MAX_CONNECTIONS=100

# Database URL (constructed from above, or override for RDS)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ----------------------------------------------------------------------------
# REDIS CACHE
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ----------------------------------------------------------------------------
# PG_TILESERV (Vector Tile Server)
# ----------------------------------------------------------------------------
TILESERV_PORT=7800
TILESERV_CORS_ORIGINS=*
TILESERV_HTTP_CACHE=public, max-age=3600

# ----------------------------------------------------------------------------
# API (FastAPI Backend)
# ----------------------------------------------------------------------------
API_PORT=8000
API_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://ccce-atlas.vercel.app

# ----------------------------------------------------------------------------
# SPECIALTY TILES (FastAPI - AI Depth + Elevation Proxy)
# ----------------------------------------------------------------------------
TILES_PORT=8001
TILES_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://ccce-atlas.vercel.app

# Mapbox token for satellite imagery and terrain
MAPBOX_TOKEN=your_mapbox_token_here

# Open Topo Data API for elevation queries
OPEN_TOPO_DATA_URL=https://api.opentopodata.org/v1

# ----------------------------------------------------------------------------
# FRONTEND (Cesium.js Map)
# ----------------------------------------------------------------------------
MAP_PORT=8080

# Cesium Ion token for 3D terrain and imagery
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Default map view (Corpus Christi, TX)
DEFAULT_LATITUDE=27.8006
DEFAULT_LONGITUDE=-97.3964
DEFAULT_HEIGHT=15000

# API endpoints (for frontend build-time substitution)
API_BASE_URL=http://localhost:8000
TILES_BASE_URL=http://localhost:8001
TILESERV_BASE_URL=http://localhost:7800

# ----------------------------------------------------------------------------
# AWS (Production Deployment)
# ----------------------------------------------------------------------------

# EC2 instance (for API and Tiles services)
EC2_INSTANCE_TYPE=t3.micro
EC2_REGION=us-east-1
EC2_AZ=us-east-1a

# RDS PostgreSQL (for PostGIS database)
RDS_INSTANCE_TYPE=db.t3.micro
RDS_REGION=us-east-1
RDS_AZ=us-east-1a
RDS_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
RDS_PORT=5432

# ElastiCache Redis (for caching)
ELASTICACHE_NODE_TYPE=cache.t3.micro
ELASTICACHE_REGION=us-east-1
ELASTICACHE_AZ=us-east-1a
ELASTICACHE_ENDPOINT=your-elasticache-endpoint.cache.amazonaws.com
ELASTICACHE_PORT=6379

# S3 bucket for static assets and large data files
S3_BUCKET=ccce-atlas
S3_REGION=us-east-1
PARCELS_S3_URL=https://ccce-atlas.s3.us-east-1.amazonaws.com/parcels_with_data.geojson

# ----------------------------------------------------------------------------
# VERCEL (Frontend Hosting)
# ----------------------------------------------------------------------------
VERCEL_PROJECT_NAME=ccce-atlas
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# ----------------------------------------------------------------------------
# MONITORING & LOGGING (Optional)
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
# JWT secret for API authentication (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# API rate limiting
RATE_LIMIT_PER_MINUTE=60
