# CCCE Atlas Production Environment Configuration
# Copy this to .env.production and fill in your values

# ============================================================================
# Database (RDS PostgreSQL)
# ============================================================================
POSTGRES_HOST=ccce-atlas-db.xxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=ccce_atlas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_RDS_PASSWORD_HERE

# Full database URL (update with your RDS endpoint and password)
DATABASE_URL=postgresql://postgres:YOUR_RDS_PASSWORD_HERE@ccce-atlas-db.xxxxx.us-east-1.rds.amazonaws.com:5432/ccce_atlas

# ============================================================================
# Redis (Local on EC2)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ============================================================================
# API Configuration
# ============================================================================
ENVIRONMENT=production
DEBUG=False

# CORS - Allow all origins for MCP access
# In production, you might want to restrict this
CORS_ORIGINS=*

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8000
HOST=0.0.0.0

# ============================================================================
# Optional: Monitoring & Logging
# ============================================================================
# LOG_LEVEL=INFO
# SENTRY_DSN=  # Add Sentry for error tracking (optional)
